  @@index([userId, createdAt])
  @@index([status])
  @@map("wallet_transactions")
}

model SpecialistSubscription {
  id           String @id @default(cuid())
  specialistId String

  // Subscription details
  planType String // PAY_PER_USE, MONTHLY_SUBSCRIPTION
  status   String @default("ACTIVE") // ACTIVE, CANCELLED, EXPIRED, PENDING

  // Billing
  monthlyRate    Decimal @default(10.0) // $10/month
  currency       String  @default("USD")
  transactionFee Decimal @default(20.0) // 20₴ per transaction for pay-per-use

  // Coinbase Commerce subscription (if applicable)
  coinbaseSubscriptionId String?

  // Telegram Stars recurring subscription: last successful charge id (used to
  // cancel auto-renewal via editUserStarSubscription) + the paying user's tg id.
  provider          String? // 'TELEGRAM_STARS' | 'DODO' | 'COINBASE' | null
  telegramChargeId  String?
  telegramPayerId   String? // Telegram user id that paid (for cancel/refund)

  // Dodo Payments (card-on-file subscription with free trial → auto-charge)
  dodoSubscriptionId String?
  dodoCustomerId     String?

  // Billing cycle
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  nextBillingDate    DateTime?

  // Plan change management
  pendingPlanType         String? // For plan changes that take effect next month
  planChangeEffectiveDate DateTime?

  // Usage tracking (for pay-per-use)
  currentMonthTransactions Int     @default(0)
  currentMonthFees         Decimal @default(0.0)

  // Payment tracking
  lastPaymentDate   DateTime?
  lastPaymentAmount Decimal?
  paymentFailures   Int       @default(0)

  // Metadata
  metadata  String? // JSON string
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  specialist User @relation(fields: [specialistId], references: [id])

  @@index([specialistId, status])
  @@index([planType, status])
  @@index([nextBillingDate])
  @@index([planChangeEffectiveDate]) // processPendingPlanChanges query
  @@index([planType, status, nextBillingDate]) // processMonthlyBilling composite
  @@map("specialist_subscriptions")
}

model PaymentWebhook {
  id String @id @default(cuid())

  // Webhook details
  provider  String // COINBASE_COMMERCE
  eventType String // charge:confirmed, charge:failed, etc.
  eventId   String @unique

  // Processing status
  status       String    @default("PENDING") // PENDING, PROCESSED, FAILED, IGNORED
  processedAt  DateTime?
  errorMessage String?

  // Webhook data
  payload   String // JSON string of full webhook payload
  signature String? // Webhook signature for verification

  // Related entities
  relatedId   String? // CryptoPayment ID, Booking ID, etc.
  relatedType String? // CRYPTO_PAYMENT, SUBSCRIPTION

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provider, eventType])
  @@index([status, createdAt])
  @@index([eventId])
  @@map("payment_webhooks")
}

// Coinbase Onramp Sessions for fiat-to-crypto conversion
model OnrampSession {
  id String @id @default(cuid())

  // User information
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Session details
  sessionToken String @unique
  status       String @default("PENDING") // PENDING, COMPLETED, FAILED, EXPIRED

  // Payment amounts
  amount         Decimal // Fiat amount
  currency       String   @default("USD") // Fiat currency
  cryptoAmount   Decimal? // Actual crypto received
  cryptoCurrency String? // USDC, ETH, BTC, etc.
  blockchain     String? // ethereum, base, bitcoin, etc.

  // Transaction details
  transactionHash String? // Blockchain transaction hash
  onrampURL       String // URL for the onramp widget

  // Purpose and related entities
  purpose   String // BOOKING_DEPOSIT, WALLET_TOPUP, SUBSCRIPTION
  bookingId String? // If for booking deposit
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  // Timing
  expiresAt   DateTime
  completedAt DateTime?

  // Metadata
  metadata String? // JSON string for additional data

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([status, expiresAt])
  @@index([sessionToken])
  @@index([purpose, status])
  @@map("onramp_sessions")
}

// Specialist Expense Tracking
model Expense {
  id           String @id @default(cuid())
  specialistId String

  // Expense details
  category    String // RENT, UTILITIES, CONSUMABLES, EQUIPMENT, INSURANCE, MARKETING, SALARIES, OTHER
  amount      Decimal
  currency    String   @default("UAH")
  description String
  date        DateTime @default(now())

  // Recurring expense settings
  isRecurring        Boolean @default(false)
  recurringFrequency String? // WEEKLY, MONTHLY, QUARTERLY, YEARLY

  // Tax / accounting
  isTaxDeductible Boolean  @default(true)
  vatAmount       Decimal? // optional VAT/input tax component
  vendorName      String?
  vendorTaxId     String?

  // Optional details
  notes      String?
  receiptUrl String?

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  specialist User @relation("SpecialistExpenses", fields: [specialistId], references: [id], onDelete: Cascade)

  @@index([specialistId, date])
  @@index([category])
  @@index([specialistId, category])
  @@map("expenses")
}

// Invoices issued by a specialist/business to a customer for completed work.
// Independent of the booking-payment flow — used for B2B invoicing and as the
// source-of-truth document for accountants and tax filings.
model Invoice {
  id           String  @id @default(cuid())
  specialistId String
  bookingId    String?
  customerId   String?

  // Document identity
  invoiceNumber String    @unique
  issueDate     DateTime  @default(now())
  dueDate       DateTime?

  // Counterparty (free-text for non-platform clients)
  clientName    String
  clientEmail   String?
  clientAddress String?
  clientTaxId   String?

  // Money
  currency   String  @default("UAH")
  subtotal   Decimal
  taxRate    Decimal @default(0)
  taxAmount  Decimal @default(0)
  total      Decimal
  amountPaid Decimal @default(0)

  // Line items stored as JSON for flexibility (description, qty, unitPrice, total).
  lineItems String // JSON array

  // Lifecycle
  status      String    @default("DRAFT") // DRAFT, SENT, PARTIAL, PAID, OVERDUE, CANCELLED, VOID
  sentAt      DateTime?
  paidAt      DateTime?
  cancelledAt DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  specialist User @relation("SpecialistInvoices", fields: [specialistId], references: [id], onDelete: Cascade)

  @@index([specialistId, issueDate])
  @@index([specialistId, status])
  @@index([bookingId])
  @@map("invoices")
}

// Multi-specialist organisation. A Business has one OWNER + 0..N MANAGERs and
// SPECIALISTs. Individual specialists who aren't part of a business simply have
// no BusinessMember row — the whole feature is opt-in.
model Business {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  ownerId     String
  email       String?
  phone       String?
  address     String?
  websiteUrl  String?
  logoUrl     String?
  currency    String   @default("UAH")
  timezone    String   @default("UTC")
  taxId       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner   User             @relation("OwnedBusinesses", fields: [ownerId], references: [id], onDelete: Cascade)
  members BusinessMember[]

  @@index([ownerId])
  @@map("businesses")
}

model BusinessMember {
  id         String    @id @default(cuid())
  businessId String
  userId     String
  role       String // OWNER, MANAGER, SPECIALIST
  invitedBy  String?
  invitedAt  DateTime  @default(now())
  joinedAt   DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation("BusinessMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([userId])
  @@map("business_members")
}

// External calendar sync (Google Calendar today, room for Apple/Microsoft later).
// One row per user × provider. Refresh token is the source of truth — access
// tokens get rotated on each use and the row updated.
model CalendarConnection {
  id                String    @id @default(cuid())
  userId            String
  provider          String // GOOGLE (future: APPLE, MICROSOFT)
  providerAccountId String?
  accessToken       String
  refreshToken      String?
  tokenExpiresAt    DateTime?
  scope             String?
  calendarId        String    @default("primary")
  calendarName      String?
  syncEnabled       Boolean   @default(true)
  lastSyncAt        DateTime?
  lastSyncError     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation("UserCalendarConnections", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("calendar_connections")
}

// Community Feature Models

model Post {
  id       String @id @default(cuid())
  authorId String

  type    String @default("DISCUSSION") // DISCUSSION, SALE
  title   String
  content String @db.Text

  // Sale-specific fields
  price        Decimal?
  currency     String?  @default("UAH")
  contactPhone String?
  contactEmail String?
  images       String? // JSON array of image URLs

  // Rent/marketplace fields
  condition     String? // NEW, USED, LIKE_NEW
  listingStatus String? @default("ACTIVE") // ACTIVE, SOLD, RENTED

  // Metrics
  viewCount    Int @default(0)
  likeCount    Int @default(0)
  commentCount Int @default(0)

  // Status
  isPublished Boolean   @default(true)
  isPinned    Boolean   @default(false)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User           @relation("UserPosts", fields: [authorId], references: [id], onDelete: Cascade)
  comments  Comment[]
  likes     PostLike[]
  bookmarks PostBookmark[]
  reports   PostReport[]

  @@index([authorId, isDeleted])
  @@index([type, isPublished, isDeleted])
  @@index([createdAt])
  @@map("posts")
}

model Comment {
  id       String  @id @default(cuid())
  postId   String
  authorId String
  parentId String? // For nested replies

  content   String @db.Text
  likeCount Int    @default(0)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post    Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User          @relation("UserComments", fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[]     @relation("CommentReplies")
  likes   CommentLike[]

  @@index([postId, isDeleted])
  @@index([parentId])
  @@map("comments")
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation("UserPostLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("post_likes")
}

model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation("UserCommentLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("comment_likes")
}

model PostBookmark {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation("UserPostBookmarks", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("post_bookmarks")
}

model PostReport {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  reason    String
  details   String?  @db.Text
  status             String    @default("PENDING")
  updatedAt          DateTime  @updatedAt
  resolvedAt         DateTime?
  reviewedByAdmin    String?
  resolutionNotes    String?
  createdAt          DateTime  @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation("UserPostReports", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("post_reports")
}

// Email delivery logs for deduplication and tracking
model EmailLog {
  id        String   @id @default(cuid())
  recipient String
  subject   String
  status    String   @default("SENT") // SENT, FAILED
  messageId String? // External email provider message ID
  error     String? // Error message if failed
  sentAt    DateTime @default(now())

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recipient, subject, sentAt]) // Dedup lookups in trial/reminder workers
  @@index([recipient, sentAt]) // Per-recipient recent emails
  @@index([sentAt]) // Cleanup/analytics queries
  @@map("email_logs")
}

// Web Push Notification Subscriptions
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("push_subscriptions")
}

// Native (Capacitor) device push tokens — FCM (Android) / APNs-via-FCM (iOS).
model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String   // 'ios' | 'android' | 'web'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("device_tokens")
}

// Waitlist Model - allows customers to join a waitlist when no slots are available
model Waitlist {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  specialistId  String
  preferredDate DateTime
  preferredTime String? // e.g., "morning", "afternoon", "evening", or specific time
  status        String    @default("WAITING") // WAITING, NOTIFIED, BOOKED, CANCELLED, EXPIRED
  notifiedAt    DateTime?
  bookedAt      DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([specialistId, preferredDate])
  @@index([userId])
  @@index([status])
  @@map("waitlists")
}

model ClientNote {
  id           String   @id @default(cuid())
  specialistId String
  customerId   String
  content      String
  category     String   @default("general") // general, allergy, preference, formula, medical
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  specialist Specialist @relation(fields: [specialistId], references: [id])
  customer   User       @relation("ClientNotes", fields: [customerId], references: [id])

  @@index([specialistId, customerId])
}

model BeforeAfterPhoto {
  id           String   @id @default(cuid())
  specialistId String
  bookingId    String?
  beforeUrl    String
  afterUrl     String
  caption      String?
  isPublic     Boolean  @default(true)
  createdAt    DateTime @default(now())

  specialist Specialist @relation(fields: [specialistId], references: [id])
  booking    Booking?   @relation(fields: [bookingId], references: [id])

  @@index([specialistId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SALON MANAGEMENT SUITE — staff invites, inventory, purchasing, payroll
// All additive; cross-entity refs (ownerId/businessId/staffUserId) are plain
// indexed columns (no FK) so adding these never touches existing models.
// ─────────────────────────────────────────────────────────────────────────────

// Pending staff invitation (email may not have an account yet).
model BusinessInvite {
  id         String    @id @default(cuid())
  businessId String
  email      String
  role       String // MANAGER | SPECIALIST
  token      String    @unique
  invitedBy  String
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
  @@index([businessId])
  @@map("business_invites")
}

// Inventory item (retail product OR consumable). ownerId = the employer/solo user.
model Product {
  id           String   @id @default(cuid())
  ownerId      String // user who owns the inventory (solo or business owner)
  businessId   String? // null for solo specialists
  sku          String?
  barcode      String? // EAN/UPC/etc. — for scanning + label printing + catalog lookup
  name         String
  description  String?
  imageUrl     String? // product photo (stored in our uploads/DB)
  type         String   @default("CONSUMABLE") // CONSUMABLE | RETAIL
  unit         String   @default("unit") // unit | ml | g | pack
  costPrice    Decimal  @default(0)
  salePrice    Decimal? // for RETAIL items
  stockQty     Decimal  @default(0)
  reorderLevel Decimal  @default(0) // low-stock threshold
  expiryDate   DateTime? // nearest batch expiry (v1: per-product; batch/lot tracking is a future enhancement)
  currency     String   @default("UAH")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  movements StockMovement[]

  @@index([ownerId])
  @@index([businessId])
  @@index([barcode])
  @@map("products")
}

// Every stock change (received, used, sold, adjusted). Sum = current stockQty.
model StockMovement {
  id          String   @id @default(cuid())
  productId   String
  delta       Decimal // +received / -used / -sold / ±adjust
  reason      String // PURCHASE | USAGE | SALE | ADJUSTMENT | RETURN
  reference   String? // PO id, booking id, free note
  createdById String
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("stock_movements")
}

// Vendor / supplier of products.
model Supplier {
  id         String   @id @default(cuid())
  ownerId    String
  businessId String?
  name       String
  email      String?
  phone      String?
  address    String?
  taxId      String?
  notes      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@index([ownerId])
  @@map("suppliers")
}

model PurchaseOrder {
  id         String    @id @default(cuid())
  ownerId    String
  businessId String?
  supplierId String?
  poNumber   String
  status     String    @default("DRAFT") // DRAFT | ORDERED | PARTIAL | RECEIVED | CANCELLED
  currency   String    @default("UAH")
  subtotal   Decimal   @default(0)
  taxAmount  Decimal   @default(0)
  total      Decimal   @default(0)
  notes      String?
  orderedAt  DateTime?
  receivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  supplier Supplier?           @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]

  @@index([ownerId])
  @@index([businessId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  productId       String? // links to inventory if known
  description     String
  quantity        Decimal
  unitCost        Decimal
  receivedQty     Decimal @default(0)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

// Commission rate per staff member (% of service price on completed bookings).
model CommissionRule {
  id          String   @id @default(cuid())
  ownerId     String // employer
  businessId  String?
  staffUserId String
  mode        String   @default("FLAT") // FLAT | TIERED
  tiers       String? // JSON: [{minRevenue, percent}] applied by period revenue (TIERED mode)
  percent     Decimal  @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([ownerId, staffUserId])
  @@index([staffUserId])
  @@map("commission_rules")
}

// A pay-run line for one staff member over a period.
model PayrollRecord {
  id              String    @id @default(cuid())
  ownerId         String // employer (business owner / solo)
  businessId      String?
  staffUserId     String // professional being paid
  periodStart     DateTime
  periodEnd       DateTime
  baseSalary      Decimal   @default(0)
  commissionTotal Decimal   @default(0)
  bonus           Decimal   @default(0)
  deductions      Decimal   @default(0)
  taxAmount       Decimal   @default(0)
  netPay          Decimal   @default(0)
  currency        String    @default("UAH")
  status          String    @default("DRAFT") // DRAFT | APPROVED | PAID
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([ownerId])
  @@index([businessId])
  @@index([staffUserId])
  @@map("payroll_records")
}

// ─────────────────────────────────────────────────────────────────────────────
// GROWTH SUITE — consumable auto-deduct, gift cards, packages, memberships,
// marketing automation. All additive; cross-entity refs are plain indexed cols.
// ─────────────────────────────────────────────────────────────────────────────

// Links a service to the products it consumes, so completing a booking writes
// the stock off automatically.
model ServiceConsumable {
  id        String   @id @default(cuid())
  serviceId String
  productId String
  quantity  Decimal  @default(1) // units consumed per booking of this service
  createdAt DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, productId])
  @@index([productId])
  @@map("service_consumables")
}

// Prepaid gift card, redeemable against bookings.
model GiftCard {
  id                String    @id @default(cuid())
  ownerId           String // issuing business owner / solo
  businessId        String?
  code              String    @unique
  initialAmount     Decimal
  balance           Decimal
  currency          String    @default("UAH")
  status            String    @default("ACTIVE") // ACTIVE | REDEEMED | EXPIRED | CANCELLED
  recipientEmail    String?
  recipientUserId   String?
  purchasedByUserId String?
  note              String?
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  transactions GiftCardTransaction[]

  @@index([ownerId])
  @@index([code])
  @@map("gift_cards")
}

model GiftCardTransaction {
  id         String   @id @default(cuid())
  giftCardId String
  amount     Decimal // negative = redeemed, positive = top-up
  reason     String // ISSUE | REDEEM | REFUND | ADJUST
  bookingId  String?
  createdAt  DateTime @default(now())

  giftCard GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)

  @@index([giftCardId])
  @@map("gift_card_transactions")
}

// Prepaid package of service credits (e.g. "10 haircuts").
model ServicePackage {
  id          String   @id @default(cuid())
  ownerId     String
  businessId  String?
  name        String
  description String?
  serviceId   String? // optional: credits valid for one service
  credits     Int      @default(1)
  price       Decimal
  currency    String   @default("UAH")
  validDays   Int      @default(365)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchases CustomerPackage[]

  @@index([ownerId])
  @@map("service_packages")
}

model CustomerPackage {
  id               String    @id @default(cuid())
  packageId        String
  customerUserId   String
  remainingCredits Int
  status           String    @default("ACTIVE") // ACTIVE | USED | EXPIRED
  purchasedAt      DateTime  @default(now())
  expiresAt        DateTime?

  package ServicePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([customerUserId])
  @@index([packageId])
  @@map("customer_packages")
}

// Recurring membership plan offered by a business.
model MembershipPlan {
  id              String   @id @default(cuid())
  ownerId         String
  businessId      String?
  name            String
  description     String?
  price           Decimal
  currency        String   @default("UAH")
  billingPeriod   String   @default("MONTHLY") // MONTHLY | YEARLY
  benefits        String? // JSON / free text
  discountPercent Decimal  @default(0) // member discount on services
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members CustomerMembership[]

  @@index([ownerId])
  @@map("membership_plans")
}

model CustomerMembership {
  id               String    @id @default(cuid())
  planId           String
  customerUserId   String
  status           String    @default("ACTIVE") // ACTIVE | CANCELLED | EXPIRED | PAST_DUE
  startedAt        DateTime  @default(now())
  currentPeriodEnd DateTime?
  cancelledAt      DateTime?

  plan MembershipPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([customerUserId])
  @@index([planId])
  @@map("customer_memberships")
}

// Configurable marketing automation (win-back, rebooking nudge, birthday).
model MarketingAutomation {
  id              String    @id @default(cuid())
  ownerId         String
  businessId      String?
  type            String // WINBACK | REBOOKING | BIRTHDAY
  isEnabled       Boolean   @default(false)
  lapsedDays      Int       @default(60) // for WINBACK: no booking in N days
  rebookDays      Int       @default(30) // for REBOOKING: nudge N days after last visit
  channel         String    @default("BOTH") // TELEGRAM | EMAIL | BOTH
  messageTemplate String?
  lastRunAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([ownerId, type])
  @@index([businessId])
  @@map("marketing_automations")
}

// Log of automation messages sent (idempotency + reporting).
model MarketingLog {
  id             String   @id @default(cuid())
  automationId   String
  customerUserId String
  channel        String
  sentAt         DateTime @default(now())

  @@index([automationId])
  @@index([customerUserId])
  @@map("marketing_logs")
}

// Retail store — a customer orders RETAIL products from a specialist/business.
// Collection happens in-store or via payments later; status tracks fulfilment.
model ProductOrder {
  id             String   @id @default(cuid())
  ownerId        String // the seller (specialist/business owner)
  businessId     String?
  customerUserId String? // null for walk-in / guest
  customerName   String?
  customerEmail  String?
  orderNumber    String
  status         String   @default("PENDING") // PENDING | PAID | FULFILLED | CANCELLED | REFUNDED
  fulfilment     String   @default("PICKUP") // PICKUP | DELIVERY
  currency       String   @default("UAH")
  subtotal       Decimal  @default(0)
  discount       Decimal  @default(0)
  total          Decimal  @default(0)
  paymentMethod  String?  // CASH | CARD | OTHER — stored for POS sales and reporting
  giftCardId     String?  // which gift card was applied (if any)
  giftCardAmount Decimal  @default(0) // amount offset by the gift card
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items ProductOrderItem[]

  @@index([ownerId])
  @@index([customerUserId])
  @@map("product_orders")
}

model ProductOrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  name      String
  quantity  Decimal
  unitPrice Decimal

  order ProductOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("product_order_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — customer tags, saved segments, segment campaigns, tasks, consent, leads
// Client-centric. specialistId / customerId are plain indexed columns (no FK to
// users/specialists) so every model here is purely additive — same convention
// as the salon suite above. A "client" is the (specialistId, customerId) pair.
// ─────────────────────────────────────────────────────────────────────────────

model CustomerTag {
  id           String   @id @default(cuid())
  specialistId String
  name         String
  color        String   @default("primary") // primary | success | warning | danger | gray | info
  createdAt    DateTime @default(now())

  assignments CustomerTagAssignment[]

  @@unique([specialistId, name])
  @@index([specialistId])
  @@map("customer_tags")
}

model CustomerTagAssignment {
  id           String   @id @default(cuid())
  tagId        String
  specialistId String
  customerId   String
  createdAt    DateTime @default(now())

  tag CustomerTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, customerId])
  @@index([specialistId, customerId])
  @@map("customer_tag_assignments")
}

model CustomerSegment {
  id           String   @id @default(cuid())
  specialistId String
  name         String
  description  String?
  filter       Json // { minSpent?, maxSpent?, lapsedDays?, activeWithinDays?, minBookings?, tagIds?: string[], hasEmail?, hasPhone? }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([specialistId])
  @@map("customer_segments")
}

model SegmentCampaign {
  id             String    @id @default(cuid())
  specialistId   String
  name           String
  channel        String    @default("email") // email | sms | push | inapp
  subject        String?
  body           String
  filter         Json? // snapshot of the audience filter at send time
  segmentId      String?
  status         String    @default("draft") // draft | sending | sent | failed
  recipientCount Int       @default(0)
  sentCount      Int       @default(0)
  openCount      Int       @default(0)
  clickCount     Int       @default(0)
  createdAt      DateTime  @default(now())
  sentAt         DateTime?

  events CampaignEvent[]

  @@index([specialistId])
  @@map("segment_campaigns")
}

model CampaignEvent {
  id         String   @id @default(cuid())
  campaignId String
  customerId String
  type       String   // "OPEN" | "CLICK"
  url        String?  // original URL for CLICK events
  createdAt  DateTime @default(now())

  campaign SegmentCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("campaign_events")
}

model ClientTask {
  id           String    @id @default(cuid())
  specialistId String
  customerId   String?
  title        String
  notes        String?
  dueDate      DateTime?
  status       String    @default("open") // open | done
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  @@index([specialistId, status])
  @@index([specialistId, customerId])
  @@map("client_tasks")
}

model MarketingConsent {
  id           String   @id @default(cuid())
  specialistId String
  customerId   String
  email        Boolean  @default(true)
  sms          Boolean  @default(true)
  push         Boolean  @default(true)
  optOutAll    Boolean  @default(false)
  source       String? // how/where consent was captured
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([specialistId, customerId])
  @@index([specialistId])
  @@map("marketing_consents")
}

model Lead {
  id           String   @id @default(cuid())
  specialistId String
  name         String
  email        String?
  phone        String?
  source       String? // walk-in | referral | instagram | web | phone | other
  stage        String   @default("new") // new | contacted | qualified | won | lost
  value        Decimal?
  notes        String?
  customerId   String? // set when converted to a real customer
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([specialistId, stage])
  @@map("leads")
}

// ─────────────────────────────────────────────────────────────────────────────
// HR SUITE — staff attendance, leave/time-off, shifts. Employees are full
// specialist accounts linked to a Business via BusinessMember. All additive;
// ownerId (employer) / businessId / staffUserId are plain indexed columns
// (no FK) — same convention as the salon & CRM suites above.
// ─────────────────────────────────────────────────────────────────────────────

// One working day per staff member: clock-in/out + computed minutes.
model Attendance {
  id            String    @id @default(cuid())
  ownerId       String // employer who manages this team (or self, for solo)
  businessId    String?
  staffUserId   String // the employee (specialist user) being tracked
  date          DateTime // normalised to the start of the working day (UTC)
  clockIn       DateTime?
  clockOut      DateTime?
  minutesWorked Int       @default(0) // computed on clock-out
  status        String    @default("PRESENT") // PRESENT | LATE | ABSENT | ON_LEAVE | HALF_DAY
  note          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([staffUserId, date])
  @@index([ownerId])
  @@index([businessId])
  @@index([staffUserId, date])
  @@map("attendance_records")
}

// Time-off request, approved/rejected by the employer.
model LeaveRequest {
  id          String    @id @default(cuid())
  ownerId     String
  businessId  String?
  staffUserId String
  type        String    @default("VACATION") // VACATION | SICK | UNPAID | OTHER
  startDate   DateTime
  endDate     DateTime
  days        Decimal   @default(1)
  reason      String?
  status      String    @default("PENDING") // PENDING | APPROVED | REJECTED | CANCELLED
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNote  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([ownerId])
  @@index([businessId])
  @@index([staffUserId, status])
  @@map("leave_requests")
}

// A scheduled shift for a staff member (feeds "late" detection + payroll hours).
model StaffShift {
  id          String   @id @default(cuid())
  ownerId     String
  businessId  String?
  staffUserId String
  startTime   DateTime
  endTime     DateTime
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
  @@index([businessId])
  @@index([staffUserId, startTime])
  @@map("staff_shifts")
}

// Guest checkout OTP — stores hashed 6-digit codes for email-verified guest booking.
// Codes expire after 10 minutes and are locked after 5 failed attempts.
// The plaintext code is NEVER stored; only a sha256 hex digest.
model GuestOtp {
  id          String    @id @default(cuid())
  email       String
  phone       String?
  name        String?
  codeHash    String    // sha256(code) hex digest
  expiresAt   DateTime
  attempts    Int       @default(0)
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([email])
  @@map("guest_otps")
}

// AI Concierge conversation log — every prompt, reply, tool call and returned
// options/products, for review + analytics.
model ConciergeLog {
  id        String   @id @default(cuid())
  userId    String?
  message   String
  reply     String
  toolCalls String   @default("[]") // JSON: [{name, args, ok}]
  options   String   @default("[]") // JSON of returned service options
  products  String   @default("[]") // JSON of returned product options
  lat       Float?
  lng       Float?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("concierge_logs")
}
