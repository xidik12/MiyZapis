  referralType   String  @default("CUSTOMER_TO_CUSTOMER") // CUSTOMER_TO_CUSTOMER, SPECIALIST_TO_CUSTOMER, CUSTOMER_TO_SPECIALIST
  targetUserType String? // CUSTOMER, SPECIALIST - who is being referred

  // Referral status
  status      String    @default("PENDING") // PENDING, COMPLETED, EXPIRED
  completedAt DateTime?

  // Points tracking
  referrerPoints Int     @default(0)
  referredPoints Int     @default(0)
  pointsAwarded  Boolean @default(false)

  // Enhanced rewards tracking
  referrerRewardType  String? // POINTS, DISCOUNT, CREDIT, CUSTOM
  referredRewardType  String? // POINTS, DISCOUNT, CREDIT, CUSTOM
  referrerRewardValue Decimal? // Monetary value or percentage for non-points rewards
  referredRewardValue Decimal? // Monetary value or percentage for non-points rewards

