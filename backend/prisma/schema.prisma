// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  password            String?
  passwordLastChanged DateTime?
  authProvider        String? // "google", "telegram", "email" - tracks how user registered/authenticated
  // Owner-managed staff: a salon owner created this professional's profile
  // directly (no login). They are bookable but can't sign in until claimed.
  isManaged           Boolean   @default(false)
  managedById         String? // the owner user who manages this profile
  dateOfBirth         DateTime? // for birthday marketing automation + greetings
  firstName           String
  lastName            String
  avatar              String?
  userType            String    @default("CUSTOMER") // "CUSTOMER", "SPECIALIST", "ADMIN"
  isGuest             Boolean   @default(false) // true for shell accounts created via guest checkout OTP

  // Contact information
  phoneNumber String?
  telegramId  String? @unique

  // Platform settings
  isEmailVerified Boolean   @default(false)
  isPhoneVerified Boolean   @default(false)
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?

  // Preferences
  language String @default("en")
  currency String @default("USD")
  timezone String @default("UTC")

  // Notification preferences
  emailNotifications    Boolean @default(true)
  pushNotifications     Boolean @default(true)
  telegramNotifications Boolean @default(true)

  // Loyalty program
  loyaltyPoints Int @default(0)

  // Wallet and Payment
  walletBalance  Decimal @default(0.0)
  walletCurrency String  @default("USD")

  // Specialist subscription
  subscriptionStatus        String    @default("PAY_PER_USE") // PAY_PER_USE, MONTHLY_SUBSCRIPTION
  subscriptionValidUntil    DateTime?
  subscriptionEffectiveDate DateTime?

  // AI Concierge entitlement (customer AI/Premium plan). Access while this is in
  // the future; null/past = no access.
  aiAccessUntil             DateTime?

  // Free trial period (3 months for both users and specialists)
  trialStartDate DateTime? // When trial started
  trialEndDate   DateTime? // When trial ends (3 months from start)
  isInTrial      Boolean   @default(true) // Quick check if user is in trial period

  // Terms of Service acceptance (recorded at registration for audit/compliance).
  termsAcceptedAt DateTime?
  termsVersion    String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  specialist          Specialist?
  customerBookings    Booking[]            @relation("CustomerBookings")
  specialistBookings  Booking[]            @relation("SpecialistBookings")
  reviews             Review[]
  payments            Payment[]
  paymentMethods      PaymentMethod[]
  notifications       Notification[]
  deviceTokens        DeviceToken[]
  loyaltyTransactions LoyaltyTransaction[]

  // Enhanced Loyalty Relations
  loyaltyTier             LoyaltyTier?             @relation("UserLoyaltyTier", fields: [loyaltyTierId], references: [id])
  loyaltyTierId           String?
  badges                  UserBadge[]
  referralsGiven          LoyaltyReferral[]        @relation("ReferrerRelation")
  referralsReceived       LoyaltyReferral[]        @relation("ReferredRelation")
  campaignRedemptions     CampaignRedemption[]
  pointsRedemptions       PointsRedemption[]
  reviewRewards           ReviewReward[]
  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  sentMessages            Message[]                @relation("SentMessages")
  receivedMessages        Message[]                @relation("ReceivedMessages")
  customerConversations   Conversation[]           @relation("CustomerConversations")
  specialistConversations Conversation[]           @relation("SpecialistConversations")
  uploadedFiles           File[]
  reportsMade             Report[]                 @relation("ReportsMade")
  reportsReceived         Report[]                 @relation("ReportsReceived")
  favoriteSpecialists     FavoriteSpecialist[]     @relation("UserFavoriteSpecialists")
  favoriteServices        FavoriteService[]        @relation("UserFavoriteServices")
  profileViews            ProfileView[]            @relation("ProfileViewer")
  profileViewsReceived    ProfileView[]            @relation("ProfileViewed")
  telegramSessions        TelegramSession[]
  createdRewards          LoyaltyReward[]          @relation("SpecialistRewards")
  rewardRedemptions       RewardRedemption[]       @relation("UserRewardRedemptions")
  walletTransactions      WalletTransaction[]
  cryptoPayments          CryptoPayment[]
  subscriptions           SpecialistSubscription[]
  onrampSessions          OnrampSession[]
  expenses                Expense[]                @relation("SpecialistExpenses")
  invoices                Invoice[]                @relation("SpecialistInvoices")
  calendarConnections     CalendarConnection[]     @relation("UserCalendarConnections")
  ownedBusinesses         Business[]               @relation("OwnedBusinesses")
  businessMemberships     BusinessMember[]         @relation("BusinessMemberships")
  // Tax regime preference used by the bookkeeping calculator endpoints.
  taxRegime               String? // UA_FOP_GROUP_3, UA_FOP_GROUP_2, KH_FLAT_10, NONE
  taxId                   String? // EDRPOU / individual TIN / similar
  pushSubscriptions       PushSubscription[]
  waitlists               Waitlist[]
  clientNotes             ClientNote[]             @relation("ClientNotes")

  // Community relations
  posts         Post[]         @relation("UserPosts")
  comments      Comment[]      @relation("UserComments")
  postLikes     PostLike[]     @relation("UserPostLikes")
  commentLikes  CommentLike[]  @relation("UserCommentLikes")
  postBookmarks PostBookmark[] @relation("UserPostBookmarks")
  postReports   PostReport[]   @relation("UserPostReports")

  // Review engagement relations
  reviewReactions   ReviewReaction[]         @relation("UserReviewReactions")
  reviewReports     ReviewReport[]           @relation("UserReviewReports")
  responseReactions ReviewResponseReaction[] @relation("UserResponseReactions")
  reviewComments    ReviewComment[]          @relation("UserReviewComments")
  commentReactions  ReviewCommentReaction[]  @relation("UserCommentReactions")

  // Indexes for performance
  @@index([email])
  @@index([telegramId])
  @@index([userType, isActive])
  @@index([userType, isActive, createdAt])
  @@index([lastLoginAt])
  @@index([isInTrial, trialEndDate]) // Trial expiration service queries
  @@index([trialStartDate]) // Trial start lookups
  @@map("users")
}

model Specialist {
  id     String @id @default(cuid())
  userId String @unique

  // Optional: link to a multi-specialist Business this person works under.
  businessId String?

  // Business profile
  businessName String?
  slug         String? @unique
  bio          String?
  bioUk        String? // Ukrainian bio
  bioRu        String? // Russian bio
  education    String? // Education background
  educationUk  String? // Ukrainian education
  educationRu  String? // Russian education

  // Professional details
  specialties String // JSON string of specialty tags
  experience  Int     @default(0) // Years of experience
  isVerified  Boolean @default(false)
  languages   String? // JSON string of supported languages

  // Reputation: external review profile links (for "leave us a review" requests)
  googleReviewUrl   String?
  facebookReviewUrl String?
  // Marketplace acquisition: featured/boosted placement in search
  isFeatured        Boolean   @default(false)
  featuredUntil     DateTime?

  // Location
  address      String?
  city         String?
  state        String?
  country      String?
  latitude     Float?
  longitude    Float?
  timezone     String  @default("UTC")
  workingHours String // JSON string for working hours

  // Detailed contact information for confirmed bookings
  preciseAddress     String? // Exact address with apartment/suite number
  businessPhone      String? // Primary business phone number
  whatsappNumber     String? // WhatsApp contact number
  locationNotes      String? // Special instructions for finding the location
  parkingInfo        String? // Parking instructions
  accessInstructions String? // Building access, buzzer codes, etc.

  // Business operations
  paymentMethods          String? // JSON string of accepted payment methods
  bankDetails             String? // JSON string of bank account details
  paymentQrCodeUrl        String? // QR code image URL for payments
  serviceArea             String? // JSON string for service area settings (radius, cities)
  notifications           String? // JSON string for notification preferences
  privacy                 String? // JSON string for privacy settings
  socialMedia             String? // JSON string for social media profiles
  autoBooking             Boolean @default(false) // Auto-approve bookings without manual confirmation
  listedInSearch          Boolean @default(true)  // Show this specialist in marketplace search results
  requireVerifiedCustomer Boolean @default(false) // Only allow registered (non-guest) customers to book
  allowPayAtVenue         Boolean @default(false)
  cancellationWindowHours Int     @default(24) // Hours before booking that cancellation is allowed (2, 6, 12, 24, 48)

  // Onboarding
  onboardingCompleted Boolean @default(false)

  // Verification details
  verifiedDate              DateTime? // Date when verified
  documentsSubmitted        String?   // JSON string of submitted documents
  verificationStatus        String    @default("NONE") // NONE, PENDING, VERIFIED, REJECTED
  verificationRequestedAt   DateTime?
  verificationNote          String?

  // Business metrics
  rating            Float @default(0.0)
  reviewCount       Int   @default(0)
  completedBookings Int   @default(0)
  responseTime      Int   @default(0) // Average response time in minutes

  // Portfolio
  portfolioImages String? // JSON string of image URLs
  certifications  String? // JSON string of certifications

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  services           Service[]
  reviews            Review[]              @relation("SpecialistReviews")
  availabilityBlocks AvailabilityBlock[]
  analytics          SpecialistAnalytics[]
  favorites          FavoriteSpecialist[]  @relation("SpecialistFavorites")
  clientNotes        ClientNote[]
  beforeAfterPhotos  BeforeAfterPhoto[]
  promotion          Promotion?

  // Indexes for performance
  @@index([city, isVerified])
  @@index([rating])
  @@index([specialties])
  @@index([isVerified])
  @@map("specialists")
}

// ---------------------------------------------------------------------------
// Promoted listing creative — the "ad" a specialist/business places on the
// marketplace. 1:1 with Specialist. Rides on the existing featured boost
// (Specialist.isFeatured) for ranking; this row holds the *creative* shown in
// the promoted card slot (search top + homepage featured). Self-serve / free
// during launch; counters here let us bill on impressions/clicks later.
// ---------------------------------------------------------------------------
model Promotion {
  id           String  @id @default(cuid())
  specialistId String  @unique
  specialist   Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)

  // Creative
  headline           String? // short hook, e.g. "Манікюр мрії у затишку"
  offerText          String? // the offer, e.g. "-20% першим клієнтам"
  imageUrl           String? // hero photo (uploaded)
  logoUrl            String? // optional brand logo
  accentColor        String? @default("#5b6b3a") // hex; defaults to olive
  highlightServiceId String? // which service the card features (name + price)
  ctaLabel           String? // CTA text; falls back to "Book" / "Записатись"

  // Curation — the platform decides what goes live. A business prepares a
  // creative (DRAFT) and submits it (PENDING_REVIEW); MiyZapis flips it to
  // ACTIVE (or PAUSED). Public showcase shows only status=ACTIVE within window.
  //   DRAFT | PENDING_REVIEW | ACTIVE | PAUSED
  status    String    @default("DRAFT")
  startsAt  DateTime? // optional scheduling window (null bounds = open-ended)
  endsAt    DateTime?

  // Lightweight performance counters (no per-event table yet)
  impressions Int @default(0)
  clicks      Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("promotions")
}

model Service {
  id           String  @id @default(cuid())
  specialistId String
  businessId   String? // optional: service offered under a multi-specialist business
  categoryId   String?
  name         String
  description  String
  category     String

  // Pricing
  basePrice Decimal
  currency  String  @default("USD")

  // Loyalty Points Pricing
  loyaltyPointsEnabled Boolean @default(false)
  loyaltyPointsPrice   Int? // Points required to book this service
  loyaltyPointsOnly    Boolean @default(false) // If true, only bookable with points

  // Service Discounts
  discountEnabled     Boolean   @default(false)
  discountType        String? // PERCENTAGE, FIXED_AMOUNT
  discountValue       Decimal? // Percentage (0-100) or fixed amount
  discountValidFrom   DateTime?
  discountValidUntil  DateTime?
  discountDescription String? // Optional description for the discount

  // Service details
  duration        Int // Duration in minutes
  prepTime        Int  @default(0)
  cleanupTime     Int  @default(0)
  rebookCycleDays Int?

  // Location details (shown to customer after payment)
  serviceLocation String? // Physical address or location details for this service
  locationNotes   String? // Additional instructions for finding the location
  latitude        Float? // Geographic latitude coordinate
  longitude       Float? // Geographic longitude coordinate

  // Requirements and deliverables
  requirements String // JSON string of requirements
  deliverables String // JSON string of deliverables

  // Settings
  isActive          Boolean @default(true)
  requiresApproval  Boolean @default(true)
  maxAdvanceBooking Int     @default(30) // Days
  minAdvanceBooking Int     @default(1) // Hours

  // Group Session Settings
  isGroupSession  Boolean @default(false) // Whether this service supports group bookings
  maxParticipants Int? // Maximum number of participants (NULL = unlimited)
  minParticipants Int     @default(1) // Minimum participants required

  // Soft deletion
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  // Service images
  images String? // JSON string of image URLs

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // No-show protection / deposit policy (per service; charging happens once
  // a payment provider is live — until then deposits are tracked as REQUIRED).
  requireDeposit          Boolean @default(false)
  depositType             String? // PERCENT | FIXED
  depositValue            Decimal @default(0)
  cancellationWindowHours Int     @default(0) // free-cancel cutoff before start
  noShowFeeType           String? // PERCENT | FIXED
  noShowFeeValue          Decimal @default(0)

  // Relations
  specialist    Specialist          @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  categoryModel Category?           @relation(fields: [categoryId], references: [id])
  bookings      Booking[]
  favorites     FavoriteService[]   @relation("ServiceFavorites")
  waitlists     Waitlist[]
  consumables   ServiceConsumable[]

  // Indexes for performance
  @@index([categoryId, isActive, isDeleted])
  @@index([specialistId, isActive, isDeleted])
  @@index([basePrice])
  @@index([isGroupSession])
  @@index([duration])
  @@index([isActive, isDeleted])
  @@index([isDeleted])
  @@map("services")
}

model Booking {
  id           String  @id @default(cuid())
  customerId   String
  specialistId String
  businessId   String? // denormalised: speeds up business-scoped queries
  serviceId    String
  promoCodeId  String?

  // Booking details
  status      String   @default("PENDING") // PENDING, PENDING_PAYMENT, CONFIRMED, IN_PROGRESS, COMPLETED, CANCELLED, REFUNDED
  scheduledAt DateTime
  duration    Int // Duration in minutes

  // Pricing
  totalAmount           Decimal
  depositAmount         Decimal
  remainingAmount       Decimal
  loyaltyPointsUsed     Int     @default(0)
  paidWithLoyaltyPoints Boolean @default(false) // True if booking was paid entirely with loyalty points

  // Deposit payment tracking
  depositStatus     String    @default("PENDING") // PENDING, PAID, REFUNDED, FORFEITED
  depositPaidAt     DateTime?
  depositRefundedAt DateTime?
  depositCurrency   String    @default("USD")
  walletAmountUsed  Decimal   @default(0.0)
  giftCardAmountUsed Decimal  @default(0.0)

  // Additional information
  customerNotes    String?
  specialistNotes  String?
  preparationNotes String?
  completionNotes  String?
  deliverables     String // JSON string of deliverables

  // Group Session Support
  participantCount Int     @default(1) // Number of participants in this booking
  groupSessionId   String? // Links multiple bookings to same group session

  // Time tracking
  confirmedAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  cancelledAt DateTime?

  // Cancellation details
  cancellationReason String?
  cancelledBy        String? // customerId or specialistId
  refundAmount       Decimal?

  // Recurring booking support
  isRecurring      Boolean   @default(false)
  recurringPattern String? // JSON: { frequency, daysOfWeek?, endType, endAfterCount?, endDate? }
  parentBookingId  String?
  parentBooking    Booking?  @relation("RecurringBookings", fields: [parentBookingId], references: [id])
  childBookings    Booking[] @relation("RecurringBookings")

  // External calendar sync — event IDs in each party's connected calendar
  calendarEventIdCustomer   String?
  calendarEventIdSpecialist String?

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  customer      User           @relation("CustomerBookings", fields: [customerId], references: [id])
  specialist    User           @relation("SpecialistBookings", fields: [specialistId], references: [id])
  service       Service        @relation(fields: [serviceId], references: [id])
  promoCode     PromoCode?     @relation(fields: [promoCodeId], references: [id])
  payments      Payment[]
  review        Review?
  notifications Notification[]
  conversations Conversation[]

  // Loyalty Relations
  pointsRedemptions PointsRedemption[]
  reviewRewards     ReviewReward[]
  rewardRedemptions RewardRedemption[] @relation("BookingRewardRedemptions")

  // Booking lifecycle automation fields
  confirmDeadlineAt   DateTime? // when the PENDING confirm window expires (null = auto-confirmed)
  reminded30Sent      Boolean   @default(false) // 30-min customer reminder sent
  postApptConfirmSent Boolean   @default(false) // post-appointment specialist confirm prompt sent

  // No-show protection state (depositStatus already exists above)
  noShowFeeAmount     Decimal   @default(0)
  noShowFeeStatus     String    @default("NONE") // NONE | CHARGED | WAIVED
  consumablesDeducted Boolean   @default(false) // guard so stock is written off once
  source              String    @default("DIRECT") // DIRECT | DISCOVERY | EMBED | MARKETPLACE — acquisition channel
  isFirstVisit        Boolean   @default(false) // customer's first-ever booking with this specialist
  reviewRequestedAt   DateTime? // when the post-visit review request was sent

  // Crypto Payment Relations
  cryptoPayments     CryptoPayment[]
  walletTransactions WalletTransaction[]
  onrampSessions     OnrampSession[]
  beforeAfterPhotos  BeforeAfterPhoto[]

  // Indexes for performance
  @@index([status, scheduledAt])
  @@index([customerId, status])
  @@index([customerId, createdAt])
  @@index([specialistId, status])
  @@index([specialistId, status, scheduledAt])
  @@index([scheduledAt])
  @@index([groupSessionId])
  @@index([scheduledAt, serviceId])
  @@index([parentBookingId])
  @@index([customerId, serviceId, scheduledAt]) // Double-booking prevention composite
  @@index([specialistId, serviceId, scheduledAt]) // Specialist schedule conflict check
  @@index([status, confirmDeadlineAt]) // Lifecycle worker: PENDING SLA expiry scan
  @@map("bookings")
}

model Payment {
  id        String  @id @default(cuid())
  userId    String
  bookingId String?

  // Payment details
  status   String // PENDING, PROCESSING, SUCCEEDED, FAILED, CANCELLED, REFUNDED
  type     String // DEPOSIT, FULL_PAYMENT, REFUND, LOYALTY_REDEMPTION, SUBSCRIPTION
  amount   Decimal
  currency String  @default("USD")

  // External payment provider info
  stripePaymentIntentId String?
  stripeChargeId        String?

  // Payment method
  paymentMethodType String? // card, telegram_payment, crypto, wallet

  // Metadata
  metadata  String? // JSON string
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user    User     @relation(fields: [userId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([status, userId])
  @@index([bookingId])
  @@map("payments")
}

model Review {
  id           String @id @default(cuid())
  bookingId    String @unique
  customerId   String
  specialistId String

  // Review content
  rating  Int // 1-5 stars
  comment String?
  tags    String // JSON string of tags like "professional", "punctual", etc.

  // Review metadata
  isPublic   Boolean @default(true)
  isVerified Boolean @default(false)

  // Engagement metrics
  likeCount    Int @default(0)
  dislikeCount Int @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  booking    Booking          @relation(fields: [bookingId], references: [id])
  customer   User             @relation(fields: [customerId], references: [id])
  specialist Specialist       @relation("SpecialistReviews", fields: [specialistId], references: [id])
  reactions  ReviewReaction[]
  reports    ReviewReport[]
  response   ReviewResponse?
  comments   ReviewComment[]

  @@index([specialistId, createdAt])
  @@index([customerId])
  @@index([rating])
  @@map("reviews")
}

model ReviewReaction {
  id       String @id @default(cuid())
  reviewId String
  userId   String

  // Reaction type: "like" or "dislike"
  reactionType String // "like" | "dislike"

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation("UserReviewReactions", fields: [userId], references: [id], onDelete: Cascade)

  // Ensure one reaction per user per review
  @@unique([reviewId, userId])
  @@index([reviewId])
  @@index([userId])
  @@map("review_reactions")
}

model ReviewReport {
  id         String @id @default(cuid())
  reviewId   String
  reportedBy String

  // Report reason
  reason  String // spam, offensive, fake, harassment, personal_info, other
  details String? // Optional additional details

  // Report status
  status String @default("PENDING") // PENDING, REVIEWING, RESOLVED, DISMISSED

  // Admin review
  reviewedByAdmin String?
  resolutionNotes String?
  resolvedAt      DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reporter User   @relation("UserReviewReports", fields: [reportedBy], references: [id], onDelete: Cascade)

  // Prevent duplicate reports from same user
  @@unique([reviewId, reportedBy])
  @@index([reviewId])
  @@index([reportedBy])
  @@index([status])
  @@index([createdAt])
  @@map("review_reports")
}

model ReviewResponse {
  id       String @id @default(cuid())
  reviewId String @unique

  // Response content
  responseText String

  // Engagement metrics for responses
  likeCount    Int @default(0)
  dislikeCount Int @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  review    Review                   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reactions ReviewResponseReaction[]

  @@index([reviewId])
  @@map("review_responses")
}

model ReviewResponseReaction {
  id         String @id @default(cuid())
  responseId String
  userId     String

  // Reaction type: "like" or "dislike"
  reactionType String // "like" | "dislike"

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  response ReviewResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  user     User           @relation("UserResponseReactions", fields: [userId], references: [id], onDelete: Cascade)

  // Ensure one reaction per user per response
  @@unique([responseId, userId])
  @@index([responseId])
  @@index([userId])
  @@map("review_response_reactions")
}

model ReviewComment {
  id       String  @id @default(cuid())
  reviewId String
  userId   String
  parentId String? // For nested replies (Reddit-style threading)

  // Comment content
  content String

  // Engagement metrics
  likeCount    Int @default(0)
  dislikeCount Int @default(0)

  // Moderation
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  review    Review                  @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User                    @relation("UserReviewComments", fields: [userId], references: [id], onDelete: Cascade)
  parent    ReviewComment?          @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   ReviewComment[]         @relation("CommentReplies")
  reactions ReviewCommentReaction[]

  @@index([reviewId])
  @@index([userId])
  @@index([parentId])
  @@index([createdAt])
  @@map("review_comments")
}

model ReviewCommentReaction {
  id        String @id @default(cuid())
  commentId String
  userId    String

  // Reaction type: "like" or "dislike"
  reactionType String // "like" | "dislike"

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  comment ReviewComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User          @relation("UserCommentReactions", fields: [userId], references: [id], onDelete: Cascade)

  // Ensure one reaction per user per comment
  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
  @@map("review_comment_reactions")
}

model LoyaltyTransaction {
  id     String @id @default(cuid())
  userId String

  // Transaction details
  type        String // EARNED, REDEEMED, EXPIRED, BONUS
  points      Int
  reason      String
  description String?

  // Transaction metadata
  referenceId String? // Reference to related booking, etc.
  expiresAt   DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, type])
  @@index([referenceId])
  @@map("loyalty_transactions")
}

model Notification {
  id     String @id @default(cuid())
  userId String
  type   String // BOOKING_CREATED, BOOKING_CONFIRMED, etc.

