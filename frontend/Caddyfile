# Static serve config for the MiyZapis frontend (Nixpacks + Caddy).
# Replaces the default-generated Caddyfile via nixpacks.toml start cmd.

{
	admin off
	persist_config off
	auto_https off
	log {
		format json
	}
	servers {
		# Coolify Traefik sits in front; trust private ranges so client IPs are correct.
		trusted_proxies static private_ranges
	}
}

:{$PORT:3000} {
	root * /app/dist
	log {
		format json
	}
	encode gzip zstd

	# Security headers applied to every response.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		# camera=(self): POS barcode scanner needs getUserMedia on our own origin.
		# camera=() would disable the camera for EVERY user/device (NotAllowedError).
		Permissions-Policy "geolocation=(self), camera=(self), microphone=(), payment=(self)"
		Cross-Origin-Opener-Policy "same-origin-allow-popups"
		Cross-Origin-Embedder-Policy "credentialless"
		Cross-Origin-Resource-Policy "cross-origin"
		# Hide Caddy fingerprint
		-Server
	}

	# Vite emits hashed asset filenames — safe to cache forever.
	@hashedAssets path /assets/*
	header @hashedAssets Cache-Control "public, max-age=31536000, immutable"

	# Service worker and manifest must always be fresh.
	@noCache path /sw.js /registerSW.js /manifest.json /manifest.webmanifest *.html
	header @noCache Cache-Control "no-cache, must-revalidate"

	# ─── Dynamic rendering for crawlers (SEO / GEO / AEO) ──────────────────
	# Search engines and AI answer engines mostly don't run JS, so this SPA's
	# content would be invisible to them. Route ONLY bot user-agents (and never
	# asset requests) to the headless-Chromium prerender service, which returns
	# fully-rendered HTML. Human traffic never matches this and is unaffected.
	@prerender {
		header_regexp ua User-Agent (?i)(googlebot|google-inspectiontool|bingbot|yandex(bot)?|duckduckbot|baiduspider|slurp|gptbot|oai-searchbot|chatgpt-user|claudebot|claude-web|anthropic-ai|perplexitybot|perplexity-user|google-extended|applebot|amazonbot|cohere-ai|bytespider|meta-externalagent|facebookexternalhit|twitterbot|telegrambot|linkedinbot|whatsapp|slackbot|discordbot|pinterest|redditbot|petalbot|semrushbot|ahrefsbot)
		not path_regexp \.(js|mjs|css|map|png|jpg|jpeg|gif|svg|webp|avif|ico|woff|woff2|ttf|eot|json|xml|txt|wasm)$
		not path /healthz
	}
	handle @prerender {
		reverse_proxy http://miyzapis-prerender:3000 {
			# Successful renders pass straight through. If the prerenderer errors,
			# fall back to the SPA shell so bots get a valid page, never a 5xx.
			@fail status 500 502 503 504
			handle_response @fail {
				root * /app/dist
				rewrite * /index.html
				file_server
			}
		}
	}

	# Static file requests: serve them if they exist, real 404 if they don't.
	# Without this, missing /favicon.svg etc. would silently fall back to index.html
	# and clients would try to parse HTML as the wrong content type.
	@staticFile path_regexp \.(js|mjs|css|map|png|jpg|jpeg|gif|svg|webp|avif|ico|woff|woff2|ttf|eot|json|xml|txt|wasm)$
	handle @staticFile {
		file_server
	}

	# SPA fallback for everything else (React Router routes).
	handle {
		try_files {path} /index.html
		file_server
	}
}
